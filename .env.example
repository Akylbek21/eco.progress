# ── Frontend ──
# Порт на localhost (host nginx проксирует сюда)
FRONTEND_PORT=3000

# URL бэкенда из контейнера фронта (через общую Docker-сеть eco-net)
# Для production: http://eco-app:8080 (имя контейнера бэкенда)
# Для dev без бэкенд-контейнера: http://host.docker.internal:8080
BACKEND_URL=http://eco-app:8080

# Dev API target for Vite proxy. Do not include `/api` at the end.
VITE_BACKEND_URL=http://213.155.20.204:8080
